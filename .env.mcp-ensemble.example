# MCP Ensemble Docker Compose Environment
# Copy this file to .env.mcp-ensemble and adjust values as needed.

COMPOSE_PROJECT_NAME=mcp-ensemble

# ---------------------------------------------------------------------------
# Per-service API keys and secrets
# ---------------------------------------------------------------------------
# Each MCP server may require its own credentials.
# The easiest way to inject them is via docker-compose overrides or by
# exporting them before running:
#
#   export STRIPE_SECRET_KEY=sk_...
#   docker compose --profile mcp up -d
#
# Because there are 202 services, setting every key individually in this file
# is impractical. Instead, export the keys you need for the subset of servers
# you intend to test.
#
# Common examples:
# STRIPE_SECRET_KEY=sk_test_...
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# GITHUB_TOKEN=ghp_...
# ---------------------------------------------------------------------------

# You can also pin the port range start if you regenerate the compose file:
# MCP_BASE_PORT=8000
