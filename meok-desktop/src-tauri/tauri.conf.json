{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MEOK",
  "version": "0.1.0",
  "identifier": "ai.meok.companion",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "MEOK",
        "width": 80,
        "height": 80,
        "minWidth": 80,
        "minHeight": 80,
        "alwaysOnTop": true,
        "decorations": false,
        "transparent": true,
        "shadow": false,
        "skipTaskbar": true,
        "resizable": false,
        "x": 100,
        "y": 100
      }
    ],
    "security": {
      "csp": null
    },
    "trayIcon": {
      "iconPath": "icons/32x32.png",
      "iconAsTemplate": true,
      "tooltip": "MEOK Companion"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "global-shortcut": null,
    "shell": {
      "open": true
    },
    "store": null
  }
}
